<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ClassIsland.SchoolStats.Controls.StatsComponentSettingsControl">
    <ScrollViewer>
        <StackPanel Spacing="12" Margin="8">

            <!-- 显示设置 -->
            <TextBlock Text="显示设置" FontSize="16" FontWeight="Bold" />
            <CheckBox x:Name="ShowProgressBarCheck" Content="显示进度条" IsChecked="True" />
            <CheckBox x:Name="ShowHoursCheck" Content="显示在校小时数" IsChecked="True" />
            <CheckBox x:Name="CompactModeCheck" Content="紧凑模式" IsChecked="False" />

            <Separator />

            <!-- 学期配置 -->
            <TextBlock Text="📅 学期配置" FontSize="16" FontWeight="Bold" />
            <StackPanel Spacing="8">
                <TextBlock Text="学期起始日期" FontSize="13" />
                <DatePicker x:Name="StartDatePicker" />
                <TextBlock Text="学期结束日期" Margin="0,8,0,0" FontSize="13" />
                <DatePicker x:Name="EndDatePicker" />
                <TextBlock Text="每日在校时长（小时）" FontSize="13" />
                <NumericUpDown x:Name="DailyHoursSpinner" Minimum="1" Maximum="24" Increment="0.5" Value="8" />
            </StackPanel>
            <CheckBox x:Name="ExcludeWeekendsCheck" Content="自动排除周末" IsChecked="True" />
            <CheckBox x:Name="NetworkHolidayCheck" Content="联网更新节假日（实验性）" IsChecked="False" />

            <Separator />

            <!-- 假期管理 -->
            <TextBlock Text="🏖️ 假期管理" FontSize="16" FontWeight="Bold" />
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox x:Name="HolidayNameInput" Watermark="假期名称" Width="150" />
                    <DatePicker x:Name="HolidayStartPicker" />
                    <TextBlock Text="~" VerticalAlignment="Center" />
                    <DatePicker x:Name="HolidayEndPicker" />
                    <Button x:Name="AddHolidayBtn" Content="添加" />
                </StackPanel>
                <ListBox x:Name="HolidayListBox" MinHeight="100" />
                <Button x:Name="RemoveHolidayBtn" Content="移除选中" />
            </StackPanel>

            <Separator />

            <!-- 调休补班 -->
            <TextBlock Text="📝 调休补班" FontSize="16" FontWeight="Bold" />
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox x:Name="WorkdayNameInput" Watermark="补班说明" Width="150" />
                    <DatePicker x:Name="WorkdayDatePicker" />
                    <Button x:Name="AddWorkdayBtn" Content="添加补班日" />
                </StackPanel>
                <ListBox x:Name="WorkdayListBox" MinHeight="60" />
                <Button x:Name="RemoveWorkdayBtn" Content="移除选中" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
