<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ClassIsland.SchoolStats.Controls.StatsComponent">
    <Panel>
        <StackPanel x:Name="MainDisplay" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock x:Name="IconLabel" Text="📚" FontSize="16" VerticalAlignment="Center" />
            <StackPanel x:Name="CompactStack" Orientation="Horizontal" Spacing="4" IsVisible="{Binding CompactMode}">
                <TextBlock x:Name="CompactDaysLabel" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                <TextBlock x:Name="CompactPercentLabel" FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel x:Name="StandardStack" Spacing="2" IsVisible="{Binding !CompactMode}">
                <TextBlock x:Name="DaysLabel" FontSize="15" FontWeight="Bold" />
                <TextBlock x:Name="HoursLabel" FontSize="11" Opacity="0.8" />
                <ProgressBar x:Name="ProgressBar" Height="4" Minimum="0" Maximum="100" MinWidth="100" />
            </StackPanel>
        </StackPanel>
        <ToolTip.Tip>
            <StackPanel Spacing="4" MaxWidth="280">
                <TextBlock x:Name="TooltipTitle" FontWeight="Bold" FontSize="13" />
                <TextBlock x:Name="TooltipDetail" FontSize="12" TextWrapping="Wrap" />
                <Separator />
                <TextBlock x:Name="TooltipExclusions" FontSize="11" TextWrapping="Wrap" Opacity="0.8" />
            </StackPanel>
        </ToolTip.Tip>
    </Panel>
</UserControl>
