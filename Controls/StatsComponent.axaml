<ci:ComponentBase xmlns="https://github.com/avaloniaui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:local="clr-namespace:ClassIsland.SchoolStats.Controls"
                  xmlns:ci="clr-namespace:ClassIsland.Core.Abstractions.Controls;assembly=ClassIsland.Core"
                  xmlns:models="clr-namespace:ClassIsland.SchoolStats.Models"
                  mc:Ignorable="d"
                  x:Class="ClassIsland.SchoolStats.Controls.StatsComponent"
                  x:TypeArguments="models:StatsComponentSettings">

    <!-- 主显示 -->
    <Panel DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:StatsComponent}}"
           ClipToBounds="True">
        <Grid x:Name="MainDisplay"
              ColumnDefinitions="Auto,*"
              MinWidth="0"
              MaxWidth="320"
              VerticalAlignment="Center">

            <!-- 图标 -->
            <TextBlock x:Name="IconLabel"
                       Grid.Column="0"
                       Text="📚"
                       FontSize="16"
                       VerticalAlignment="Center" />

            <Grid Grid.Column="1"
                  Margin="6,0,0,0"
                  MinWidth="0">
                <!-- 紧凑模式：仅显示剩余时间和进度 -->
                <Grid x:Name="CompactStack"
                      ColumnDefinitions="*,Auto"
                      MinWidth="0"
                      IsVisible="False">
                    <TextBlock x:Name="CompactDaysLabel"
                               Grid.Column="0"
                               MinWidth="0"
                               MaxLines="1"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="CompactPercentLabel"
                               Grid.Column="1"
                               Margin="4,0,0,0"
                               MaxLines="1"
                               FontSize="11"
                               Opacity="0.7"
                               VerticalAlignment="Center" />
                </Grid>

                <!-- 标准模式 -->
                <Grid x:Name="StandardStack"
                      ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto,Auto"
                      MinWidth="0">
                    <TextBlock x:Name="DaysLabel"
                               Grid.Row="0"
                               Grid.Column="0"
                               MinWidth="0"
                               MaxLines="1"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               FontSize="14"
                               FontWeight="Bold" />
                    <TextBlock x:Name="WeekLabel"
                               Grid.Row="0"
                               Grid.Column="1"
                               Margin="8,0,0,0"
                               MinWidth="0"
                               MaxLines="1"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               FontSize="10"
                               HorizontalAlignment="Right"
                               Opacity="0.8" />
                    <TextBlock x:Name="HoursLabel"
                               Grid.Row="1"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               MinWidth="0"
                               MaxLines="1"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               FontSize="10"
                               Opacity="0.8" />
                    <ProgressBar x:Name="ProgressBar"
                                 Grid.Row="2"
                                 Grid.Column="0"
                                 Grid.ColumnSpan="2"
                                 Margin="0,1,0,0"
                                 Height="2"
                                 Minimum="0"
                                 Maximum="100"
                                 MinWidth="0"
                                 HorizontalAlignment="Stretch" />
                </Grid>
            </Grid>

        </Grid>

        <!-- 悬停展开详情 (Tooltip) -->
        <ToolTip.Tip>
            <ScrollViewer MaxWidth="360"
                          MaxHeight="420"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="TooltipTitle"
                               FontWeight="Bold"
                               FontSize="13"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="TooltipDetail"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <Separator x:Name="TooltipSeparator" />
                    <TextBlock x:Name="TooltipExclusions"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Opacity="0.8" />
                </StackPanel>
            </ScrollViewer>
        </ToolTip.Tip>
    </Panel>

</ci:ComponentBase>
